2	aantehe	tehe	VERB	_	NounClass=Bantu2|Tense=Past	0	root	_	Gloss=2.AGR-PST-see|Morph=aa-n-tehe|Eng=saw
3	boonge	oonge	NOUN	_	NounClass=Bantu2|Number=Plur	2	obj	_	Gloss=2-children|Eng=children

# sent_id = bas-hm2014-np-poss
